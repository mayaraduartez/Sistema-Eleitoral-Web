<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/style.css">
  <title>Gerenciar Eleitores</title>
</head>
<body>
  <div class="container-eleitor">
    <div class="cabecalho">
      <div class="subtitle">
        <h1>Gerenciar Eleitores</h1>
        <p>Gerencie os eleitores cadastrados no sistema de forma segura e eficiente.</p>
      </div>

      <div class="imagem">
        <img src="images/Tribunal_Superior_Eleitoral.png" alt="Justiça Eleitoral">
      </div>

      <div class="info">
        <p>Consulte dados oficiais da Justiça Eleitoral</p>
      </div>
    </div>

    <div class="tabela-eleitores">
      <h2>Lista de Eleitores</h2>

      <table class="tabela">
        <thead>
          <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Status</th>
            <th class="col-acoes">Ações</th>
          </tr>
        </thead>

         <tbody>
        <% eleitores.forEach(eleitor => { %>
          <tr>
            <td><%= eleitor.nome %> <%= eleitor.sobrenome %></td>
            <td><%= eleitor.cpf %></td>
            <td>
              <%= eleitor.status === 'ativo' ? 'Ativo' : 'Inativo' %>
            </td>
            <td class="acoes">

              <!-- Botões Inativar e Excluir -->
              <form 
                action="/eleitor/<%= eleitor.status === 'ativo' ? 'inativar' : 'ativar' %>/<%= eleitor.id %>" 
                method="POST"
              >
                <button class="botao-inativar"
                  type="submit" 
                  class="btn <%= eleitor.status === 'ativo' ? 'btn-danger' : 'btn-success' %>"
                >
                  <%= eleitor.status === 'ativo' ? 'Inativar' : 'Ativar' %>
                </button>
              </form>
              <form action="/eleitor/excluir/<%= eleitor.id %>" method="POST" onsubmit="return confirmarExclusao()">
                <button class="botao-excluir" type="submit">Excluir</button>
              </form>

            </>
          </tr>
        <% }) %>
      </tbody>
      </table>
    </div>
  </div>
</body>
<script>
function confirmarExclusao() {
    return confirm("Tem certeza que deseja excluir este eleitor?");
}
</script>
</html>